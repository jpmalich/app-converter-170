# Copy to backend/.env and fill in. The server FAILS CLOSED at import if any
# of the required (✅) vars are missing or invalid.

# --- Database (✅) ---------------------------------------------------------
# In Docker, `mongo` is the compose service name. Locally use localhost.
MONGO_URL=mongodb://mongo:27017
DB_NAME=proquote

# --- Auth / admin (✅) -----------------------------------------------------
# JWT_SECRET must be >= 32 chars:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# JWT_TTL_SECONDS=604800   # optional, default 7 days

# --- CORS (✅) -------------------------------------------------------------
# Explicit allowlist; empty = all cross-origin refused. With the nginx proxy
# the frontend is same-origin so this is mostly belt-and-suspenders.
CORS_ORIGINS=http://localhost:3000

# --- Supplier admin surface -----------------------------------------------
SUPPLIER_ADMIN_TOKEN=
# SIGNUP_CODE=ALSIDE-XXXXXX   # optional; stable fallback derived from JWT_SECRET

# --- AI features (optional) -----------------------------------------------
# AI routes (ai_measure, ai_blueprint, hover vision) use Emergent's LLM proxy.
# EMERGENT_LLM_KEY=
# GOOGLE_MAPS_API_KEY=

# --- Email (optional) ------------------------------------------------------
# RESEND_API_KEY=
# SENDER_EMAIL=onboarding@resend.dev
